# PRISM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────
# Core API
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ─────────────────────────────────────────────
# LLM Configuration — change here to swap models without touching code
# ─────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS_ORCHESTRATOR=250
LLM_MAX_TOKENS_EMOTIONAL=180
LLM_MAX_TOKENS_EVENT=150
LLM_TEMPERATURE=0.3

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./prism_dev.db
POSTGRES_USER=prism_user
POSTGRES_PASSWORD=prism_pass
POSTGRES_DB=prism_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Agent Score Thresholds — business logic constants
# ─────────────────────────────────────────────
TRUST_GOOD_RATING_MIN=4.0
TRUST_HIGH_RETURN_RATE=10.0
TRUST_MEDIUM_RETURN_RATE=5.0
TRUST_SCORE_GOOD=18
TRUST_SCORE_MEDIUM=-7
TRUST_SCORE_BAD=-15

BUDGET_PRICE_TREND_HIGH=5.0
BUDGET_PRICE_TREND_LOW=-5.0
BUDGET_SCORE_STABLE=5
BUDGET_SCORE_RISING=-7
BUDGET_SCORE_FALLING=10
BUDGET_SCORE_OVER_BUDGET=-20

TIME_DELIVERY_FAST_DAYS=3
TIME_SCORE_FAST=9
TIME_SCORE_NORMAL=4
TIME_SCORE_LATE=-12
TIME_SCORE_UNREACHABLE=-25

# ─────────────────────────────────────────────
# Confidence Genome
# ─────────────────────────────────────────────
CONFIDENCE_BASE_SCORE=60
CONFIDENCE_PINCODE_MATCH_BOOST=12
CONFIDENCE_MAX=98
CONFIDENCE_MIN=10

# ─────────────────────────────────────────────
# Temporal Simulator
# ─────────────────────────────────────────────
TEMPORAL_SALE_DISCOUNT=0.80
TEMPORAL_SPLIT_FRACTION=0.55
TEMPORAL_WAIT_DAYS=6
